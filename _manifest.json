{
  "manifest_version": 2,
  "version": "2.0.1",
  "name": "天气预报插件",
  "description": "定时获取指定地区天气并推送到群聊，支持手动查询指定地点天气",
  "author": {
    "name": "白狐",
    "url": "https://github.com/whitefox20011120"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/whitefox20011120/weather-forecast"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "config.get",
    "chat.get_stream_by_group_id",
    "llm.generate"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "whitefox.weather-forecast",
  "plugin_type": "service"
}
